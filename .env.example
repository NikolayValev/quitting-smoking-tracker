# ─── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used for account deletion (admin operations)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site URL ─────────────────────────────────────────────
# Production: your deployed domain (e.g. https://example.com)
# Development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─── Upstash Redis (rate limiting) ────────────────────────
# Free tier at upstash.com → create Redis database → REST API
# If not set, rate limiting is disabled (safe for local dev)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Sentry (error tracking) ──────────────────────────────
# Free tier at sentry.io → create Next.js project
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
# For source map uploads during CI/CD:
SENTRY_AUTH_TOKEN=your-sentry-auth-token
